    function renderSnippets() {
        const c=document.getElementById('snippets-list');
        c.innerHTML='';
        snippets.forEach((s,i)=>{
            const card=document.createElement('div');
            card.className='snippet-card';
            card.dataset.idx=i;
            card.innerHTML=`
                <div style="flex-grow:1;display:flex;align-items:center;gap:6px;">
                    <span class="snip-text" style="flex-grow:1;">${escapeHtml(s)}</span>
                </div>
                <button class="snip-icon-btn" onclick="copyRawText(${JSON.stringify(s).replace(/"/g,'&quot;')})" title="Copier">📋</button>
                <button class="snip-icon-btn" onclick="editSnippet(${i})" title="Modifier">✎</button>
                <button class="snip-icon-btn" onclick="removeSnippet(${i})" title="Supprimer" style="color:#ef4444;">✕</button>`;
            c.appendChild(card);
        });
    }
    function editSnippet(i) {
        const cards=document.querySelectorAll('#snippets-list .snippet-card');
        const card=cards[i];
        if(!card) return;
        card.classList.add('editing');
        const textSpan=card.querySelector('.snip-text');
        const currentVal=snippets[i];
        // Remplacer le contenu par un textarea inline
        const inner=card.querySelector('div');
        inner.innerHTML='';
        const ta=document.createElement('textarea');
        ta.className='snippet-edit-input';
        ta.value=currentVal;
        ta.rows=Math.max(1,Math.ceil(currentVal.length/50));
        ta.style.width='100%';
        inner.appendChild(ta);
        ta.focus();
        ta.setSelectionRange(ta.value.length,ta.value.length);
        // Masquer les boutons edit/copy, garder uniquement Valider et Annuler
        card.querySelectorAll('.snip-icon-btn').forEach(b=>b.style.display='none');
        const btnOk=document.createElement('button');
        btnOk.className='snip-icon-btn';
        btnOk.title='Valider';
        btnOk.textContent='✓';
        btnOk.style.color='var(--ok)';
        const btnCancel=document.createElement('button');
        btnCancel.className='snip-icon-btn';
        btnCancel.title='Annuler';
        btnCancel.textContent='✕';
        card.appendChild(btnOk);
        card.appendChild(btnCancel);
        const commit=()=>{
            const newVal=ta.value.trim();
            if(newVal&&newVal!==currentVal){
                snippets[i]=newVal;
                persistSnippets();
                renderQuickSnippets();
            }
            renderSnippets();
        };
        const cancel=()=>renderSnippets();
        btnOk.onclick=commit;
        btnCancel.onclick=cancel;
        ta.addEventListener('keydown',e=>{
            if(e.key==='Enter'&&!e.shiftKey){e.preventDefault();commit();}
            if(e.key==='Escape'){e.preventDefault();cancel();}
        });
    }
    function removeSnippet(i) {
        snippets.splice(i,1); persistSnippets();
        renderSnippets(); renderQuickSnippets();
    }
    function renderQuickSnippets() {
        const c=document.getElementById('quick-snippets');
        if(!c) return;
        c.innerHTML='';
        snippets.forEach(s=>{
            c.innerHTML+=`<div class="snippet-card" style="padding:8px 10px;font-size:.82rem;" onclick="copyRawText(${JSON.stringify(s).replace(/"/g,'&quot;')})">${escapeHtml(getReplacedText(s))}</div>`;
        });
        if(!snippets.length) c.innerHTML='<div style="font-size:.75rem;color:var(--text-muted);text-align:center;padding:8px 0;">Aucune phrase enregistrée</div>';
    }
    function addSnippet() {
