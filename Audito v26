    function editSnippet(i) {
        const cards=document.querySelectorAll('#snippets-list .snippet-card');
        const card=cards[i];
        if(!card) return;
        card.classList.add('editing');
        const textSpan=card.querySelector('.snip-text');
        const currentVal=snippets[i];
        // Remplacer le contenu par un textarea inline
        const inner=card.querySelector('div');
        inner.innerHTML='';
        const ta=document.createElement('textarea');
        ta.className='snippet-edit-input';
        ta.value=currentVal;
        ta.rows=Math.max(1,Math.ceil(currentVal.length/50));
        ta.style.width='100%';
        inner.appendChild(ta);
        ta.focus();
        ta.setSelectionRange(ta.value.length,ta.value.length);
        // Masquer les boutons edit/copy, garder uniquement Valider et Annuler
        card.querySelectorAll('.snip-icon-btn').forEach(b=>b.style.display='none');
        const btnOk=document.createElement('button');
        btnOk.className='snip-icon-btn';
        btnOk.title='Valider';
        btnOk.textContent='тЬУ';
        btnOk.style.color='var(--ok)';
        const btnCancel=document.createElement('button');
        btnCancel.className='snip-icon-btn';
        btnCancel.title='Annuler';
        btnCancel.textContent='тЬХ';
        card.appendChild(btnOk);
        card.appendChild(btnCancel);
        const commit=()=>{
            const newVal=ta.value.trim();
            if(newVal&&newVal!==currentVal){
                snippets[i]=newVal;
                persistSnippets();
                renderQuickSnippets();
            }
            renderSnippets();
        };
        const cancel=()=>renderSnippets();
        btnOk.onclick=commit;
        btnCancel.onclick=cancel;
        ta.addEventListener('keydown',e=>{
            if(e.key==='Enter'&&!e.shiftKey){e.preventDefault();commit();}
            if(e.key==='Escape'){e.preventDefault();cancel();}
        });
    }
    function removeSnippet(i) {
        snippets.splice(i,1); persistSnippets();
        renderSnippets(); renderQuickSnippets();
    }
    function renderQuickSnippets() {
        const c=document.getElementById('quick-snippets');
        c.innerHTML='';
