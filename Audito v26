    function addQ() {
        const v=document.getElementById('temp-q').value.trim();
        if(!v) return;
        if(v.startsWith('---')&&v.endsWith('---')) currentQs.push({type:'section',text:v,declaration:''});
        else currentQs.push({type:'qa',question:v,declaration:''});
        document.getElementById('temp-q').value='';
        renderEd(); onEditorChange();
    }
    function updateQuestionField(i,field,value) {
        if(!currentQs[i]) return;
        currentQs[i][field]=value;
        onEditorChange();
    }

    /* Drag & drop */
    function onDragStart(i,ev){dragSrcIndex=i;ev.dataTransfer.effectAllowed='move';ev.dataTransfer.setData('text/plain',String(i));}
    function onDragOver(ev){ev.preventDefault();ev.dataTransfer.dropEffect='move';}
    function onDrop(target,ev){
        ev.preventDefault();
        const src=dragSrcIndex!==null?dragSrcIndex:Number(ev.dataTransfer.getData('text/plain'));
        if(Number.isNaN(src)||src===target) return;
        const [moved]=currentQs.splice(src,1);currentQs.splice(target,0,moved);
        dragSrcIndex=null;renderEd();onEditorChange();
    }
    function onDragEnd(){dragSrcIndex=null;document.querySelectorAll('.editor-row.drag-over').forEach(el=>el.classList.remove('drag-over'));}
    function moveQuestion(i,dir){
        const ni=i+dir;if(ni<0||ni>=currentQs.length) return;
        [currentQs[i],currentQs[ni]]=[currentQs[ni],currentQs[i]];
        renderEd();onEditorChange();
    }

    function renderEd() {
        const c=document.getElementById('editor-list');
        c.innerHTML=currentQs.map((item,i)=>{
            const sec=isSection(item);
            return `
            <div class="editor-row drag-drop-row"
                 style="display:flex;align-items:flex-start;gap:8px;padding:8px;border:1px solid transparent;border-radius:8px;margin-bottom:6px;"
