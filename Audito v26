            const d=getReplacedText(s);
            c.innerHTML+=`<div class="snippet-card" style="padding:10px;font-size:.85rem;margin-bottom:5px" onclick="copyRawText(${JSON.stringify(s).replace(/"/g,'&quot;')})">${escapeHtml(d)}</div>`;
        });
        c.innerHTML+=`<div style="font-size:.75rem;color:var(--text-muted);text-align:center;cursor:pointer;margin-top:5px;" onclick="navTo('view-snippets')">G├йrer tout...</div>`;
    }
    function addSnippet() {
        const v=document.getElementById('new-snip').value;
        if(v){snippets.push(v);persistSnippets();renderSnippets();renderQuickSnippets();document.getElementById('new-snip').value='';}
    }

