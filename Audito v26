       EXPORT / IMPORT / RESET
    тХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХР */
    function exportData() {
        const blob=new Blob([JSON.stringify({v:26,data,snippets,meta})],{type:'application/json'});
        const a=document.createElement('a');a.href=URL.createObjectURL(blob);a.download='audito_backup_v26.json';a.click();
    }
    function importData(inp) {
        const r=new FileReader();
        r.onload=e=>{
            try{
                const j=JSON.parse(e.target.result);
                data=normalizeDataCollection(j.data||[]);
                snippets=Array.isArray(j.snippets)?j.snippets:[];
                if (j.meta && typeof j.meta==='object') meta={...defaultMeta,...j.meta};
                persistData();persistSnippets();persistMeta();
                location.reload();
            } catch{alert('Erreur de lecture du fichier.');}
        };
