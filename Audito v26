            <div class="editor-row drag-drop-row"
                 style="display:flex;align-items:flex-start;gap:8px;padding:8px;border:1px solid transparent;border-radius:8px;margin-bottom:6px;"
                 ondragover="onDragOver(event)" ondrop="onDrop(${i},event)"
                 ondragenter="this.classList.add('drag-over')" ondragleave="this.classList.remove('drag-over')">
                <span class="drag-handle" draggable="true" ondragstart="onDragStart(${i},event)" ondragend="onDragEnd()" title="Glisser">⠿</span>
                <div style="display:flex;gap:4px;flex-shrink:0;">
                    <button class="mini-btn" onclick="moveQuestion(${i},-1)">↑</button>
                    <button class="mini-btn" onclick="moveQuestion(${i},1)">↓</button>
                </div>
                <div style="flex-grow:1;">
                    ${sec?`
                        <div class="editor-col-label">Section</div>
                        <input class="editor-input" value="${escapeHtml(item.text||'')}" oninput="updateQuestionField(${i},'text',this.value)">
                    `:`
                        <div class="editor-grid">
                            <div>
                                <div class="editor-col-label">Question</div>
                                <textarea class="editor-input" oninput="updateQuestionField(${i},'question',this.value)">${escapeHtml(item.question||'')}</textarea>
                            </div>
                            <div class="editor-declaration-col">
                                <div class="editor-col-label" style="color:var(--primary);">📝 Déclaration victime</div>
                                <textarea class="editor-input" placeholder="Facultatif…" oninput="updateQuestionField(${i},'declaration',this.value)">${escapeHtml(item.declaration||'')}</textarea>
