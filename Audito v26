    /* тХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХР
       ├ЙDITEUR тАФ CONSTRUCTION
    тХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХРтХР */
    function buildIconPicker(selected) {
        const picker=document.getElementById('icon-picker');
        picker.innerHTML='';
        ICONS.forEach(ico=>{
            const el=document.createElement('span');
            el.className='icon-opt'+(ico===selected?' selected':'');
            el.textContent=ico;
            el.onclick=()=>{
                currentEditorIcon=ico;
                document.querySelectorAll('.icon-opt').forEach(x=>x.classList.remove('selected'));
                el.classList.add('selected');
                onEditorChange();
            };
            picker.appendChild(el);
        });
    }
    function buildSubcatOptions(cat,selected) {
        const sel=document.getElementById('edit-subcat');
        sel.innerHTML='<option value="">тАФ Sous-cat├йgorie тАФ</option>';
        (SUBCATS[cat]||[]).forEach(sc=>{
            const opt=document.createElement('option');
            opt.value=sc;opt.textContent=sc;
            if(sc===selected) opt.selected=true;
            sel.appendChild(opt);
        });
    }
    function onCatChange() {
        buildSubcatOptions(document.getElementById('edit-cat').value,'');
        onEditorChange();
    }

    function openEditor(id) {
        currentQs=[];currentEditorIcon='ЁЯУБ';
        document.getElementById('edit-id').value='';
        document.getElementById('edit-title').value='';
        document.getElementById('edit-title').classList.remove('input-error');
