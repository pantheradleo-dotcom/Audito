<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Audito V26</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/canvas-confetti@1.6.0/dist/confetti.browser.min.js"></script>
    <style>
        /* ══ TOKENS ══ */
        :root {
            --bg-app:#F3F4F6; --bg-sidebar:#111827; --bg-card:#FFFFFF; --bg-input:#FFFFFF;
            --text-main:#1F2937; --text-muted:#6B7280; --border:#E5E7EB;
            --primary:#2563EB; --primary-light:#EFF6FF;
            --fav:#F59E0B; --fav-light:rgba(245,158,11,.12);
            --ok:#10B981; --ok-light:rgba(16,185,129,.12);
            --warn:#EF4444; --warn-light:rgba(239,68,68,.1);
            color-scheme:light;
        }
        [data-theme="dark"] {
            --bg-app:#0f172a; --bg-sidebar:#020617; --bg-card:#1e293b; --bg-input:#334155;
            --text-main:#f1f5f9; --text-muted:#94a3b8; --border:#334155;
            --primary:#60a5fa; --primary-light:rgba(96,165,250,.15);
            --fav:#FBBF24; --fav-light:rgba(251,191,36,.12);
            --ok:#34D399; --ok-light:rgba(52,211,153,.12);
            --warn:#F87171; --warn-light:rgba(248,113,113,.1);
            color-scheme:dark;
        }
        /* ══ BASE ══ */
        *{margin:0;padding:0;box-sizing:border-box;}
        body{font-family:'Inter',sans-serif;background:var(--bg-app);color:var(--text-main);height:100vh;display:flex;overflow:hidden;transition:background .3s,color .3s;}
        ::-webkit-scrollbar{width:8px;height:8px;}
        ::-webkit-scrollbar-track{background:var(--bg-app);}
        ::-webkit-scrollbar-thumb{background:var(--text-muted);border-radius:4px;}
        ::-webkit-scrollbar-thumb:hover{background:var(--primary);}

        /* ══ SIDEBAR ══ */
        .sidebar{width:260px;background:var(--bg-sidebar);color:white;display:flex;flex-direction:column;padding:24px;border-right:1px solid rgba(255,255,255,.05);flex-shrink:0;transition:width .25s,padding .25s,min-width .25s;overflow:hidden;min-width:260px;}
        .sidebar.collapsed{width:0!important;padding:0!important;min-width:0!important;}
        .brand{font-size:1.4rem;font-weight:700;margin-bottom:30px;display:flex;align-items:center;gap:10px;}
        .brand span{color:var(--primary);}
        .nav-item{padding:12px 16px;margin-bottom:5px;border-radius:8px;cursor:pointer;display:flex;align-items:center;gap:12px;color:#94a3b8;font-weight:500;transition:.2s;}
        .nav-item:hover,.nav-item.active{background:rgba(255,255,255,.1);color:white;}
        .sidebar-footer{margin-top:auto;padding-top:20px;border-top:1px solid rgba(255,255,255,.1);display:flex;flex-direction:column;gap:10px;}

        /* ══ LAYOUT ══ */
        .main-area{flex-grow:1;display:flex;flex-direction:column;overflow:hidden;}
        .view-section{display:none;height:100%;padding:40px;overflow-y:auto;}
        .view-section.active{display:block;}
        #view-audition.active{display:flex;flex-direction:column;padding:0;overflow:hidden;}

        /* ══ INPUTS / BTN ══ */
        .search-input,.editor-input{width:100%;background:var(--bg-input);border:1px solid var(--border);padding:12px;border-radius:8px;color:var(--text-main);outline:none;transition:.2s;font:inherit;}
        .search-input:focus,.editor-input:focus{border-color:var(--primary);box-shadow:0 0 0 3px rgba(37,99,235,.1);}
        .editor-input{padding:10px 12px;}
        textarea.editor-input{min-height:72px;resize:vertical;line-height:1.55;}
        select.search-input{appearance:none;background-image:url("data:image/svg+xml;charset=UTF-8,%3csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24' fill='none' stroke='%236B7280' stroke-width='2' stroke-linecap='round' stroke-linejoin='round'%3e%3cpolyline points='6 9 12 15 18 9'%3e%3c/polyline%3e%3c/svg%3e");background-repeat:no-repeat;background-position:right 10px center;background-size:1em;}
        .action-btn{background:var(--primary);color:white;border:none;padding:12px 24px;border-radius:8px;font-weight:600;cursor:pointer;display:inline-flex;align-items:center;gap:8px;width:100%;justify-content:center;transition:.2s;font:inherit;}
        .action-btn:hover{opacity:.92;}
        .action-btn:active{transform:scale(.98);}
        .mini-btn{font-size:.75rem;background:var(--bg-card);border:1px solid var(--border);padding:4px 8px;border-radius:4px;cursor:pointer;color:var(--text-main);font-weight:600;font:inherit;}
        .mini-btn:hover{background:var(--primary);color:white;border-color:var(--primary);}

        /* ══ DASHBOARD ══ */
        .grid-cards{display:grid;grid-template-columns:repeat(auto-fill,minmax(210px,1fr));gap:18px;margin-bottom:10px;}
        .card{background:var(--bg-card);border:1px solid var(--border);border-radius:12px;padding:22px;cursor:pointer;display:flex;flex-direction:column;gap:10px;position:relative;transition:.2s;}
        .card:hover{transform:translateY(-3px);border-color:var(--primary);box-shadow:0 4px 12px rgba(0,0,0,.06);}
        .card.is-fav{border-color:var(--fav);background:linear-gradient(135deg,var(--bg-card) 80%,var(--fav-light));}
        .card-tag{align-self:flex-start;padding:4px 8px;border-radius:6px;font-size:.7rem;font-weight:700;text-transform:uppercase;}
        .tag-v{background:rgba(56,189,248,.15);color:#0ea5e9;}
        .tag-m{background:rgba(244,63,94,.15);color:#f43f5e;}
        .tag-t{background:rgba(16,185,129,.15);color:#10b981;}
        .card-actions{position:absolute;top:10px;right:10px;display:flex;gap:4px;opacity:0;transition:.2s;}
        .card:hover .card-actions{opacity:1;}
        /* Bouton favori toujours visible si actif */
        .fav-btn{font-size:.9rem;background:none;border:none;cursor:pointer;padding:3px;border-radius:4px;transition:.15s;line-height:1;}
        .fav-btn:hover{transform:scale(1.2);}
        .fav-indicator{position:absolute;top:8px;left:10px;font-size:.85rem;line-height:1;}
        /* Badge usage */
        .usage-badge{font-size:.68rem;color:var(--text-muted);display:flex;align-items:center;gap:3px;}

        .cat-header{display:flex;align-items:center;gap:12px;margin:22px 0 10px 0;}
        .section-title{font-size:.8rem;font-weight:700;color:var(--text-muted);text-transform:uppercase;letter-spacing:1px;}
        .subcat-bar{display:flex;gap:6px;flex-wrap:wrap;margin-bottom:12px;}
        .subcat-chip{display:inline-flex;align-items:center;padding:3px 12px;border-radius:20px;background:var(--bg-app);border:1px solid var(--border);font-size:.72rem;font-weight:600;color:var(--text-muted);cursor:pointer;transition:.15s;}
        .subcat-chip.active,.subcat-chip:hover{background:var(--primary);color:white;border-color:var(--primary);}

        /* Zone Récents / Favoris */
        .dash-zone{margin-bottom:6px;}
        .dash-zone-title{font-size:.75rem;font-weight:700;text-transform:uppercase;letter-spacing:1px;color:var(--text-muted);margin-bottom:10px;display:flex;align-items:center;gap:8px;}
        .mini-cards{display:flex;gap:10px;flex-wrap:wrap;margin-bottom:4px;}
        .mini-card{background:var(--bg-card);border:1px solid var(--border);border-radius:10px;padding:12px 14px;cursor:pointer;display:flex;align-items:center;gap:10px;transition:.15s;min-width:0;max-width:220px;}
        .mini-card:hover{border-color:var(--primary);background:var(--primary-light);}
        .mini-card.is-fav{border-color:var(--fav);}
        .mini-card-icon{font-size:1.1rem;flex-shrink:0;}
        .mini-card-text{font-size:.82rem;font-weight:600;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;}
        .mini-card-sub{font-size:.72rem;color:var(--text-muted);overflow:hidden;text-overflow:ellipsis;white-space:nowrap;}

        /* ══ AUDIT SIDEBAR ══ */
        /* ══ BARRE OUTILS AUDITION ══ */
        .audit-toolbar{display:flex;align-items:center;gap:8px;padding:10px 16px;background:var(--bg-card);border-bottom:1px solid var(--border);flex-shrink:0;flex-wrap:wrap;}
        .audit-toolbar-sep{width:1px;height:22px;background:var(--border);margin:0 2px;flex-shrink:0;}
        .audit-toolbar-group{display:flex;align-items:center;gap:5px;}
        .tb-label{font-size:.68rem;font-weight:700;text-transform:uppercase;color:var(--text-muted);letter-spacing:.6px;white-space:nowrap;}
        .tb-input{background:var(--bg-input);border:1px solid var(--border);padding:5px 9px;border-radius:6px;color:var(--text-main);outline:none;font:inherit;font-size:.8rem;width:128px;transition:.15s;}
        .tb-input:focus{border-color:var(--primary);}
        .tb-toggle{display:flex;align-items:center;gap:4px;padding:5px 9px;border-radius:6px;border:1px solid var(--border);background:var(--bg-app);cursor:pointer;font-size:.77rem;font-weight:600;color:var(--text-muted);transition:.15s;white-space:nowrap;user-select:none;}
        .tb-toggle:hover{border-color:var(--primary);color:var(--primary);}
        .tb-toggle.active{background:var(--primary-light);border-color:var(--primary);color:var(--primary);}
        .tb-toggle .dot{width:7px;height:7px;border-radius:50%;background:currentColor;flex-shrink:0;}
        .tb-btn{padding:5px 12px;border-radius:6px;border:1px solid var(--border);background:var(--bg-app);color:var(--text-main);cursor:pointer;font:inherit;font-size:.8rem;font-weight:600;transition:.15s;white-space:nowrap;display:inline-flex;align-items:center;gap:4px;}
        .tb-btn:hover{border-color:var(--primary);color:var(--primary);background:var(--primary-light);}
        .tb-btn.primary{background:var(--primary);color:white;border-color:var(--primary);}
        .tb-btn.primary:hover{opacity:.9;}
        /* Panneau phrases rapides escamotable */
        .audit-snip-panel{width:0;min-width:0;overflow:hidden;background:var(--bg-card);border-left:0 solid var(--border);display:flex;flex-direction:column;transition:width .25s ease,min-width .25s,border-left-width .25s;flex-shrink:0;}
        .audit-snip-panel.open{width:230px;min-width:230px;border-left-width:1px;}
        .audit-snip-panel-inner{width:230px;padding:14px;display:flex;flex-direction:column;gap:6px;overflow-y:auto;}
        .audit-snip-title{font-size:.68rem;font-weight:700;text-transform:uppercase;color:var(--text-muted);letter-spacing:.6px;margin-bottom:2px;}
        /* Corps audition */
        .audit-body{flex-grow:1;display:flex;overflow:hidden;}
        .audit-paper-zone{flex-grow:1;background:var(--bg-app);padding:20px 32px;overflow-y:auto;display:flex;flex-direction:column;align-items:center;}
        .progress-bar-wrap{width:100%;max-width:860px;margin-bottom:10px;flex-shrink:0;}
        .progress-bar-top{display:flex;align-items:center;justify-content:space-between;margin-bottom:4px;}
        .progress-label{font-size:.75rem;font-weight:600;color:var(--text-muted);}
        .progress-counter{font-size:.75rem;font-weight:700;color:var(--primary);background:var(--primary-light);padding:2px 10px;border-radius:20px;}
        .progress-track{height:4px;background:var(--border);border-radius:4px;overflow:hidden;}
        .progress-fill{height:100%;background:var(--primary);border-radius:4px;transition:width .4s;}
        .paper-search-wrap{width:100%;max-width:860px;margin-bottom:10px;flex-shrink:0;}
        .paper-search-wrap input{background:var(--bg-card);border:1px solid var(--border);padding:7px 14px;border-radius:8px;width:100%;color:var(--text-main);outline:none;font:inherit;font-size:.88rem;transition:.2s;}
        .paper-search-wrap input:focus{border-color:var(--primary);}
        .audit-paper{background:var(--bg-card);width:100%;max-width:860px;min-height:400px;border-radius:12px;border:1px solid var(--border);padding:40px 52px;box-shadow:0 4px 20px rgba(0,0,0,.05);transition:background .3s;}
        /* Déclaration victime — bouton copie */
        .q-declaration-copy{background:none;border:1px solid rgba(37,99,235,.25);color:var(--primary);font-size:.7rem;padding:2px 8px;border-radius:4px;cursor:pointer;font-family:inherit;font-weight:600;opacity:0;transition:.15s;margin-left:auto;flex-shrink:0;}
        .q-declaration-box:hover .q-declaration-copy{opacity:1;}
        .q-declaration-copy:hover{background:var(--primary);color:white;}
        /* Toggles (conservé pour compatibilité éditeur) */
        .toggle-switch{width:36px;height:20px;background:#9ca3af;border-radius:20px;position:relative;cursor:pointer;transition:.3s;flex-shrink:0;}
        .toggle-switch::after{content:'';position:absolute;top:2px;left:2px;width:16px;height:16px;background:white;border-radius:50%;transition:.3s;}
        .toggle-switch.active{background:var(--primary);}
        .toggle-switch.active::after{left:18px;}
        /* Sidebar escamotable */
        .sidebar-expand-btn{position:fixed;left:0;top:50%;transform:translateY(-50%);background:var(--bg-sidebar);color:#94a3b8;border:none;border-radius:0 6px 6px 0;padding:10px 6px;cursor:pointer;z-index:10;font-size:.85rem;display:none;}

        /* ══ BLOCS Q ══ */
        .paper-q{margin-bottom:0;position:relative;transition:.15s;padding:18px 20px;border-radius:10px;border:1px solid transparent;background:var(--bg-card);}
        .paper-q+.paper-q{margin-top:10px;}
        .paper-q:hover{background:var(--primary-light);border-color:var(--primary);}
        .paper-q:hover .q-actions{opacity:1;}
        .paper-q.q-hidden{display:none;}
        .q-num-badge{display:inline-flex;align-items:center;justify-content:center;min-width:26px;height:26px;background:var(--primary-light);color:var(--primary);border-radius:6px;font-size:.72rem;font-weight:700;margin-right:10px;flex-shrink:0;border:1px solid rgba(37,99,235,.2);}
        .q-header{display:flex;align-items:flex-start;margin-bottom:6px;}
        .q-content{font-size:1.05rem;color:var(--text-main);line-height:1.55;flex-grow:1;padding-top:3px;}
        .q-answer-zone{margin-top:10px;margin-left:36px;font-size:.95rem;color:var(--text-muted);font-style:italic;border-bottom:1px dashed var(--border);padding-bottom:6px;min-height:22px;}
        .q-actions{position:absolute;right:12px;top:12px;opacity:0;transition:.2s;display:flex;align-items:center;gap:4px;}
        .q-highlight{background:rgba(250,204,21,.4);border-radius:3px;}
        .q-declaration-box{margin-top:14px;margin-left:36px;background:var(--primary-light);border-left:3px solid var(--primary);border-radius:0 8px 8px 0;padding:12px 16px;}
        .q-declaration-header{display:flex;align-items:center;gap:6px;margin-bottom:8px;justify-content:flex-start;}
        .q-declaration-icon{font-size:.85rem;}
        .q-declaration-title{font-size:.72rem;font-weight:700;text-transform:uppercase;color:var(--primary);letter-spacing:.6px;}
        .q-declaration-text{color:var(--text-main);line-height:1.6;white-space:pre-wrap;font-size:.95rem;}
        .paper-section-divider{display:flex;align-items:center;gap:12px;margin:28px 0 18px 0;}
        .paper-section-divider .section-label{color:var(--primary);font-weight:700;font-size:.78rem;text-transform:uppercase;letter-spacing:1.5px;white-space:nowrap;padding:4px 10px;background:var(--primary-light);border-radius:6px;}
        .paper-section-divider::before,.paper-section-divider::after{content:'';flex-grow:1;height:1px;background:var(--border);}
        .style-bold .q-content{font-weight:700;}
        .style-response .q-answer-zone::before{content:"Réponse : ";font-weight:600;font-style:normal;}

        /* ══ SNIPPETS ══ */
        .snippet-card{background:var(--bg-card);border:1px solid var(--border);padding:14px;border-radius:8px;margin-bottom:10px;cursor:pointer;transition:.1s;display:flex;align-items:center;gap:8px;}
        .snippet-card:hover{border-color:var(--primary);background:var(--primary-light);}
        .snippet-card.editing{border-color:var(--primary);background:var(--bg-card);cursor:default;}
        .snippet-edit-input{flex-grow:1;background:transparent;border:none;outline:none;font:inherit;font-size:inherit;color:var(--text-main);padding:0;resize:none;line-height:1.5;}
        .snippet-edit-input:focus{outline:none;}
        .snip-icon-btn{flex-shrink:0;background:none;border:none;cursor:pointer;padding:3px 5px;border-radius:4px;color:var(--text-muted);font-size:.85rem;transition:.15s;line-height:1;}
        .snip-icon-btn:hover{background:var(--primary-light);color:var(--primary);}

        /* ══ MODALS ══ */
        .modal-wrap{position:fixed;inset:0;background:rgba(0,0,0,.7);z-index:99;display:none;align-items:center;justify-content:center;backdrop-filter:blur(2px);}

        /* Modal éditeur */
        .modal-box-editor{background:var(--bg-card);width:min(1100px,calc(100vw - 30px));height:min(94vh,960px);border-radius:16px;border:1px solid var(--border);display:flex;flex-direction:column;overflow:hidden;transition:width .25s ease;}
        .modal-box-editor.preview-open{width:min(1560px,calc(100vw - 30px));}
        .modal-editor-header{display:flex;align-items:center;justify-content:space-between;padding:16px 24px;border-bottom:1px solid var(--border);flex-shrink:0;}
        .modal-editor-body{display:flex;flex-grow:1;overflow:hidden;}

        /* Formulaire */
        .editor-form-col{flex-grow:1;min-width:0;display:flex;flex-direction:column;overflow:hidden;}
        .editor-form-meta{padding:14px 18px;border-bottom:1px solid var(--border);flex-shrink:0;display:flex;flex-direction:column;gap:10px;}
        .editor-form-meta-row{display:flex;gap:8px;}
        .editor-form-list{flex-grow:1;overflow-y:auto;padding:10px 18px;}
        .editor-add-row{padding:10px 18px;border-top:1px solid var(--border);display:flex;gap:8px;flex-shrink:0;}

        /* Statut éditeur */
        .editor-status-bar{display:flex;align-items:center;gap:8px;flex-wrap:wrap;padding:8px 18px;border-bottom:1px solid var(--border);background:var(--bg-app);flex-shrink:0;}
        .status-chip{display:inline-flex;align-items:center;gap:4px;padding:3px 9px;border-radius:20px;font-size:.72rem;font-weight:600;border:1px solid transparent;}
        .status-chip.ok{background:var(--ok-light);color:var(--ok);border-color:rgba(16,185,129,.3);}
        .status-chip.warn{background:var(--warn-light);color:var(--warn);border-color:rgba(239,68,68,.3);}
        .status-chip.neutral{background:var(--bg-card);color:var(--text-muted);border-color:var(--border);}
        .status-chip.ready{background:var(--ok-light);color:var(--ok);border-color:rgba(16,185,129,.3);font-weight:700;}
        /* Input titre en erreur */
        .input-error{border-color:var(--warn)!important;box-shadow:0 0 0 3px rgba(239,68,68,.1)!important;}

        /* Aperçu */
        .editor-preview-col{width:0;min-width:0;overflow:hidden;display:flex;flex-direction:column;background:var(--bg-app);border-left:0 solid var(--border);transition:width .25s ease,min-width .25s;}
        .preview-open .editor-preview-col{width:440px;min-width:440px;border-left:1px solid var(--border);}
        .editor-preview-header{padding:9px 18px;border-bottom:1px solid var(--border);font-size:.72rem;font-weight:700;text-transform:uppercase;color:var(--text-muted);letter-spacing:1px;background:var(--bg-card);flex-shrink:0;white-space:nowrap;}
        .editor-preview-scroll{flex-grow:1;overflow-y:auto;padding:18px;}
        .preview-paper{background:var(--bg-card);border-radius:10px;border:1px solid var(--border);padding:22px;box-shadow:0 2px 8px rgba(0,0,0,.04);}
        .preview-toggle-btn{font-size:.8rem;padding:6px 12px;border-radius:6px;border:1px solid var(--border);background:var(--bg-app);color:var(--text-muted);cursor:pointer;font:inherit;transition:.15s;display:inline-flex;align-items:center;gap:5px;}
        .preview-toggle-btn:hover,.preview-toggle-btn.active{background:var(--primary-light);color:var(--primary);border-color:var(--primary);}
        .editor-footer{padding:14px 24px;border-top:1px solid var(--border);display:flex;justify-content:space-between;align-items:center;flex-shrink:0;background:var(--bg-card);}

        /* Drag & drop */
        .editor-row.drag-over{background:var(--primary-light);border-color:var(--primary);}
        .drag-handle{cursor:grab;user-select:none;padding:4px 8px;border-radius:6px;border:1px solid var(--border);background:var(--bg-card);font-family:'JetBrains Mono',monospace;}
        .drag-handle:active{cursor:grabbing;}
        .editor-grid{display:grid;grid-template-columns:minmax(320px,1.4fr) minmax(260px,1fr);gap:12px;flex-grow:1;}
        .editor-col-label{font-size:.72rem;text-transform:uppercase;font-weight:700;color:var(--text-muted);margin-bottom:5px;}
        .editor-hint{font-size:.75rem;color:var(--text-muted);margin-top:5px;}
        .editor-declaration-col textarea.editor-input{min-height:88px;line-height:1.6;border-left:3px solid var(--primary);border-radius:0 8px 8px 0;padding-left:14px;background:var(--primary-light);}
        .editor-declaration-col textarea.editor-input:focus{background:var(--bg-input);}

        /* Icon picker */
        .icon-picker{display:flex;gap:5px;flex-wrap:wrap;margin-top:5px;}
        .icon-opt{font-size:1.15rem;width:32px;height:32px;display:flex;align-items:center;justify-content:center;border-radius:6px;border:2px solid transparent;cursor:pointer;transition:.15s;background:var(--bg-app);}
        .icon-opt:hover{border-color:var(--primary);}
        .icon-opt.selected{border-color:var(--primary);background:var(--primary-light);}

        /* Modal générique */
        .modal-box{background:var(--bg-card);width:min(520px,calc(100vw - 40px));padding:28px;border-radius:16px;border:1px solid var(--border);display:flex;flex-direction:column;gap:14px;max-height:90vh;overflow-y:auto;}

        /* Composite */
        .composite-source-item{display:flex;align-items:center;justify-content:space-between;padding:10px 12px;border-radius:8px;border:1px solid var(--border);background:var(--bg-app);cursor:pointer;transition:.15s;}
        .composite-source-item:hover{border-color:var(--primary);}
        .composite-source-item.selected{border-color:var(--primary);background:var(--primary-light);}
        .composite-order-item{display:flex;align-items:center;gap:8px;padding:8px 12px;border-radius:8px;background:var(--primary-light);border:1px solid var(--border);font-size:.9rem;}

        /* ══ MODAL HISTORIQUE ══ */
        .history-entry{display:flex;align-items:flex-start;gap:10px;padding:12px 14px;border-radius:8px;border:1px solid var(--border);background:var(--bg-app);transition:.15s;}
        .history-entry:hover{border-color:var(--primary);background:var(--primary-light);}
        .history-meta{flex-grow:1;min-width:0;}
        .history-date{font-size:.78rem;font-weight:700;color:var(--primary);}
        .history-summary{font-size:.78rem;color:var(--text-muted);margin-top:2px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;}
        .history-empty{text-align:center;padding:30px 0;color:var(--text-muted);font-size:.88rem;}
        /* ══ NOTE MODÈLE ══ */
        .model-note-field{width:100%;background:var(--bg-input);border:1px solid var(--border);padding:8px 10px;border-radius:6px;color:var(--text-muted);outline:none;font:inherit;font-size:.8rem;resize:vertical;min-height:52px;transition:.15s;line-height:1.5;}
        .model-note-field:focus{border-color:var(--primary);color:var(--text-main);}
        .model-note-field::placeholder{font-style:italic;}
        /* ══ RACCOURCI CLAVIER DASHBOARD ══ */
        .kbd-hint{position:absolute;bottom:8px;right:10px;font-size:.6rem;background:var(--bg-app);border:1px solid var(--border);color:var(--text-muted);padding:1px 5px;border-radius:3px;font-family:'JetBrains Mono',monospace;opacity:0;transition:.15s;pointer-events:none;}
        .card:hover .kbd-hint{opacity:.7;}
        /* ══ TAGS LIBRES ══ */
        .tag-chip{display:inline-flex;align-items:center;gap:3px;padding:2px 8px;border-radius:20px;font-size:.68rem;font-weight:600;background:rgba(139,92,246,.12);color:#7c3aed;border:1px solid rgba(139,92,246,.25);cursor:default;}
        [data-theme="dark"] .tag-chip{background:rgba(167,139,250,.12);color:#a78bfa;border-color:rgba(167,139,250,.25);}
        .tag-chip-rm{cursor:pointer;opacity:.6;margin-left:2px;line-height:1;}
        .tag-chip-rm:hover{opacity:1;color:#ef4444;}
        .tag-filter-chip{display:inline-flex;align-items:center;padding:3px 12px;border-radius:20px;background:var(--bg-app);border:1px solid rgba(139,92,246,.3);font-size:.72rem;font-weight:600;color:#7c3aed;cursor:pointer;transition:.15s;}
        .tag-filter-chip.active,.tag-filter-chip:hover{background:#7c3aed;color:white;border-color:#7c3aed;}
        [data-theme="dark"] .tag-filter-chip{color:#a78bfa;border-color:rgba(167,139,250,.3);}
        [data-theme="dark"] .tag-filter-chip.active,[data-theme="dark"] .tag-filter-chip:hover{background:#7c3aed;color:white;}
        .tag-input-wrap{display:flex;gap:6px;align-items:center;flex-wrap:wrap;margin-top:6px;}
        .tag-input{flex:1;min-width:120px;background:var(--bg-input);border:1px solid var(--border);padding:6px 10px;border-radius:6px;color:var(--text-main);outline:none;font:inherit;font-size:.82rem;}
        .tag-input:focus{border-color:#7c3aed;}
        /* ══ DRAG DASHBOARD ══ */
        .card.dragging{opacity:.4;transform:scale(.97);}
        .card.drag-target{border:2px dashed var(--primary)!important;background:var(--primary-light)!important;}
        /* ══ DRAG QUESTIONS CONSULTATION ══ */
        .paper-q.q-dragging{opacity:.35;}
        .paper-q.q-drag-over{border-top:3px solid var(--primary);}
        .q-drag-handle{cursor:grab;color:var(--text-muted);font-size:.95rem;padding:0 4px;opacity:0;transition:opacity .15s;flex-shrink:0;user-select:none;}
        .q-drag-handle:active{cursor:grabbing;}
        .paper-q:hover .q-drag-handle{opacity:.5;}
        /* ══ MODAL IMPORT SÉLECTIF ══ */
        .import-item{display:flex;align-items:center;gap:10px;padding:10px 12px;border-radius:8px;border:1px solid var(--border);background:var(--bg-app);transition:.15s;}
        .import-item.selected{border-color:var(--primary);background:var(--primary-light);}
        .import-item-cb{width:18px;height:18px;accent-color:var(--primary);cursor:pointer;flex-shrink:0;}
        .import-conflict{font-size:.72rem;color:var(--warn);margin-top:2px;}
        /* Responsive */
        @media(max-width:900px){.editor-grid{grid-template-columns:1fr;}.audit-sidebar{width:260px;}.audit-paper{padding:30px 20px;}}
        /* ══ IMPRESSION ══ */
        @media print {
            body{overflow:visible!important;height:auto!important;}
            .sidebar,.audit-toolbar,.paper-search-wrap,.progress-bar-wrap,.q-actions,.q-drag-handle,.q-declaration-copy{display:none!important;}
            .main-area,.view-section{overflow:visible!important;height:auto!important;}
            #view-audition.active{display:block!important;overflow:visible!important;}
            .audit-body{display:block!important;overflow:visible!important;}
            .audit-snip-panel{display:none!important;}
            .audit-paper-zone{padding:0!important;overflow:visible!important;display:block!important;}
            .audit-paper{box-shadow:none!important;border:none!important;padding:10mm 15mm!important;max-width:100%!important;width:100%!important;min-height:0!important;}
            .paper-q{break-inside:avoid;border:none!important;background:transparent!important;padding:6px 0!important;}
            .paper-q:hover{background:transparent!important;}
            .paper-section-divider{break-after:avoid;}
            .q-declaration-box{break-inside:avoid;}
            .q-answer-zone{min-height:32px!important;border-bottom:1px solid #ccc!important;}
        }
    </style>
</head>
