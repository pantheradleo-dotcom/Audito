    function getEditorValidation() {
        const title = (document.getElementById('edit-title')?.value||'').trim();
        const qCount = currentQs.filter(i=>!isSection(i)&&(i.question||'').trim()).length;
        const sCount = currentQs.filter(i=>isSection(i)).length;
        const hasTitle = title.length > 0;
        const hasQuestions = qCount > 0;
        const isValid = hasTitle && hasQuestions;
        return { title, qCount, sCount, hasTitle, hasQuestions, isValid };
    }

    function renderEditorStatusBar() {
        const bar = document.getElementById('editor-status-bar');
        if (!bar) return;
        const v = getEditorValidation();
        const cat = document.getElementById('edit-cat')?.value||'';
        const subcat = document.getElementById('edit-subcat')?.value||'';
        const target = document.getElementById('edit-target')?.value||'';

        let chips = '';

        // Statut global
        if (v.isValid) {
            chips += `<span class="status-chip ready">✓ Prêt à enregistrer</span>`;
        } else if (!v.hasTitle) {
            chips += `<span class="status-chip warn">⚠ Titre manquant</span>`;
        } else {
            chips += `<span class="status-chip warn">⚠ Incomplet</span>`;
        }

        // Compteurs
        chips += `<span class="status-chip neutral">❓ ${v.qCount} question${v.qCount!==1?'s':''}</span>`;
        if (v.sCount > 0)
            chips += `<span class="status-chip neutral">§ ${v.sCount} section${v.sCount!==1?'s':''}</span>`;
        if (!v.hasQuestions && v.sCount > 0)
            chips += `<span class="status-chip warn">Aucune vraie question</span>`;

        // Métadonnées
        chips += `<span class="status-chip neutral">${escapeHtml(currentEditorIcon)} ${escapeHtml(CAT_LABELS[cat]||cat)}${subcat?' › '+escapeHtml(subcat):''}</span>`;
        const tagCol = target==='Victime'?'#0ea5e9':target==='Témoin'?'#10b981':'#f43f5e';
        chips += `<span class="status-chip neutral" style="color:${tagCol}">● ${escapeHtml(target)}</span>`;
        if(currentEditorTags.length) chips += currentEditorTags.map(t=>`<span class="status-chip neutral" style="color:#7c3aed;background:rgba(139,92,246,.1);border-color:rgba(139,92,246,.25);">#${escapeHtml(t)}</span>`).join('');

        bar.innerHTML = chips;

        // Bordure rouge sur le titre si vide
        const titleEl = document.getElementById('edit-title');
        if (titleEl) titleEl.classList.toggle('input-error', !v.hasTitle);
    }

