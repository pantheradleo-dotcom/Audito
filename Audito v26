<script>
    /* ══════════════════════════════════════
       STOCKAGE — clés centralisées + migration
    ══════════════════════════════════════ */
    const SK = {
        data:     'audito25_data',
        snippets: 'audito25_snippets',
        theme:    'audito25_theme',
        meta:     'audito25_meta',  // favoris, récents, usages
        history:  'audito25_history'  // historique par modèle (5 versions)
    };
    // Anciennes clés connues (ordre de priorité décroissante)
    const OLD_KEYS = {
        data:     ['audito24_data','audito21_data'],
        snippets: ['audito24_snippets','audito21_snippets'],
        theme:    ['audito24_theme','audito21_theme']
    };

    function lsGet(key, fallback=null) {
        try { const v=localStorage.getItem(key); return v!==null?JSON.parse(v):fallback; }
        catch { return fallback; }
    }
    function lsSet(key, value) {
        try { localStorage.setItem(key, JSON.stringify(value)); } catch {}
    }

    /** Lit une valeur depuis la nouvelle clé, ou migre depuis une ancienne si nécessaire. */
    function lsGetMigrate(newKey, oldKeys, fallback) {
        const existing = lsGet(newKey, null);
        if (existing !== null) return existing;            // nouvelle clé déjà présente
        for (const old of (oldKeys||[])) {
            const v = lsGet(old, null);
            if (v !== null) {
                lsSet(newKey, v);                          // migration non-destructive
                return v;
            }
        }
        return fallback;
    }

    /* ══════════════════════════════════════
       CONSTANTES
    ══════════════════════════════════════ */
    const ICONS = ['📁','🤕','🚗','💊','⚖️','🏠','👤','🗒️','🔍','📋','🚨','💬','🤝','📌','🔎','✍️'];
    const CAT_LABELS = { personnes:'Personnes', biens:'Biens', route:'Route', stups:'Stups' };
    const SUBCATS = {
        personnes:['Violences','Menaces','Harcèlement','Séquestration','Enlèvement','Viol','Agression sexuelle'],
        biens:    ['Vol','Escroquerie','Dégradations','Cambriolage','Recel','Extorsion'],
        route:    ['Accident','Alcool / Stupéfiants','Défaut assurance','Délit de fuite','Excès de vitesse'],
        stups:    ['Usage','Trafic','Transport','Recel','Production']
    };
    const RECENTS_MAX = 7;
    const HISTORY_MAX = 5;
    const TOP_MAX = 5;

    const defaultData = [{
        id:'1', cat:'personnes', subcat:'Violences', icon:'🤕',
        title:'Violences', target:'Victime',
        qs:[
            {type:'section',text:'--- FAITS ---'},
            {type:'qa',question:'Pouvez-vous nous expliquer les faits ?',declaration:''},
            {type:'qa',question:'Connaissez-vous [NOM] ?',declaration:''},
            {type:'section',text:'--- JUSTICE ---'},
            {type:'qa',question:'Déposez-vous plainte ?',declaration:''}
        ]
    }];
    const defaultSnippets = ['Désire garder le silence.','Demande un avocat.','Notification des droits à [NOM].'];
    const defaultMeta = { favorites:[], recents:[], usages:{} };

    /* ══════════════════════════════════════
       ÉTAT GLOBAL
    ══════════════════════════════════════ */
    let data=[], snippets=[], meta={...defaultMeta};
    let currentQs=[], activeAudit=null;
    let styles={bold:true,resp:true,num:false};
    let dragSrcIndex=null;
    let currentEditorIcon='📁';
    let compositeSelected=[];
    let activeCatFilter=null, activeSubcatFilter=null;
    let editorPreviewVisible=false;
    let doneStates={};        // { idx: bool } — session seulement
    let currentEditorTags=[]; // tags en cours d'édition
    let activeTagFilter=null; // tag sélectionné dans le dashboard
    let importPending=null;   // données JSON en attente d'import sélectif
    let dashDragSrc=null;     // id source pour drag dashboard

    /* ══════════════════════════════════════
       INIT
    ══════════════════════════════════════ */
    function init() {
        // Données avec migration automatique
        data = normalizeDataCollection(
            lsGetMigrate(SK.data, OLD_KEYS.data, defaultData)
        );
        snippets = lsGetMigrate(SK.snippets, OLD_KEYS.snippets, defaultSnippets);
        if (!Array.isArray(snippets)) snippets = defaultSnippets;

        const rawMeta = lsGet(SK.meta, null);
        meta = rawMeta ? { ...defaultMeta, ...rawMeta } : { ...defaultMeta };
        // Assurer les champs obligatoires
        if (!Array.isArray(meta.favorites)) meta.favorites=[];
        if (!Array.isArray(meta.recents))   meta.recents=[];
        if (typeof meta.usages !== 'object' || !meta.usages) meta.usages={};

        const theme = lsGetMigrate(SK.theme, OLD_KEYS.theme, null);
        if (theme === 'dark') toggleTheme(true);

        persistData();
        persistMeta();
        renderDashboard();
        renderSnippets();
        renderQuickSnippets();
    }

    /* ══════════════════════════════════════
       PERSISTANCE
    ══════════════════════════════════════ */
    function persistData()    { lsSet(SK.data, data); }
    function persistSnippets(){ lsSet(SK.snippets, snippets); }
    function persistMeta()    { lsSet(SK.meta, meta); }

    /* ══════════════════════════════════════
       NORMALISATION
    ══════════════════════════════════════ */
    function normalizeDataCollection(col) {
        return (Array.isArray(col)?col:[]).map(item=>({
            ...item, subcat:item.subcat||'', icon:item.icon||'📁',
            tags:Array.isArray(item.tags)?item.tags:[],
            note:item.note||'',
            qs:normalizeQuestions(item.qs||[])
        }));
    }
    function normalizeQuestions(qs) { return (Array.isArray(qs)?qs:[]).map(normalizeQuestionEntry); }
    function normalizeQuestionEntry(e) {
        if (typeof e==='string') {
            const t=e.trim();
            return (t.startsWith('---')&&t.endsWith('---'))
                ? {type:'section',text:e,declaration:''}
                : {type:'qa',question:e,declaration:''};
        }
        if (e&&typeof e==='object') {
            if (e.type==='section'||(typeof e.text==='string'&&e.text.trim().startsWith('---')&&e.text.trim().endsWith('---')))
                return {type:'section',text:e.text||'--- SECTION ---',declaration:''};
            return {type:'qa',question:e.question||e.q||'',declaration:e.declaration||e.victimStatement||''};
        }
        return {type:'qa',question:'',declaration:''};
    }
    function isSection(item) { return item&&item.type==='section'; }

    /* ══════════════════════════════════════
       TAGS ÉDITEUR
    ══════════════════════════════════════ */
    function renderEditorTags() {
        const wrap=document.getElementById('edit-tags-display');
        if(!wrap) return;
        wrap.innerHTML=currentEditorTags.map((t,i)=>
            `<span class="tag-chip">#${escapeHtml(t)}<span class="tag-chip-rm" onclick="removeEditorTag(${i})">✕</span></span>`
        ).join('');
    }
    function onTagKeydown(e) {
        if(e.key==='Enter'||e.key===','){
            e.preventDefault();
            const val=e.target.value.trim().replace(/^#+/,'').replace(/[,;]/g,'').toLowerCase();
            if(val&&!currentEditorTags.includes(val)){
                currentEditorTags.push(val);
                renderEditorTags();
                onEditorChange();
            }
            e.target.value='';
        }
    }
    function removeEditorTag(i){
        currentEditorTags.splice(i,1);
        renderEditorTags();
        onEditorChange();
    }

    /* ══════════════════════════════════════
       FAVORIS / RÉCENTS / USAGES
    ══════════════════════════════════════ */
    function isFav(id)        { return meta.favorites.includes(id); }
    function toggleFav(id, ev) {
        if (ev) ev.stopPropagation();
        if (isFav(id)) meta.favorites=meta.favorites.filter(x=>x!==id);
        else meta.favorites.push(id);
        persistMeta();
        renderDashboard();
    }

    function trackOpen(id) {
        // Récents : remonter en tête si déjà présent
        meta.recents = [id, ...meta.recents.filter(x=>x!==id)].slice(0, RECENTS_MAX);
        // Usages
        meta.usages[id] = (meta.usages[id]||0) + 1;
        persistMeta();
    }

    function getTopUsed() {
        return Object.entries(meta.usages)
            .sort((a,b)=>b[1]-a[1])
            .slice(0, TOP_MAX)
            .map(([id])=>id)
            .filter(id=>data.find(x=>x.id===id));
    }

    /* ══════════════════════════════════════
       UTILITAIRES
    ══════════════════════════════════════ */
    function escapeHtml(v) {
        return String(v||'').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;').replace(/'/g,'&#39;');
    }
    function getReplacedText(text) {
        const raw=String(text||'');
        const nom=document.getElementById('var-nom').value||'[NOM]';
        const date=document.getElementById('var-date').value||new Date().toLocaleDateString();
        const h=new Date().getHours(), m=String(new Date().getMinutes()).padStart(2,'0');
        return raw.replace(/\[NOM\]/g,nom).replace(/\[DATE\]/g,date).replace(/\[HEURE\]/g,`${h}h${m}`);
    }
    function showFeedback(msg) {
        confetti({particleCount:40,spread:40,origin:{y:.9}});
        const el=document.createElement('div');
        el.innerText=msg;
        el.style.cssText='position:fixed;bottom:30px;left:50%;transform:translateX(-50%);background:var(--primary);color:white;padding:10px 22px;border-radius:20px;z-index:999;box-shadow:0 4px 10px rgba(0,0,0,.2);pointer-events:none;';
        document.body.appendChild(el);
        setTimeout(()=>el.remove(),1100);
    }

    /* ══════════════════════════════════════
       THÈME
    ══════════════════════════════════════ */
    function toggleTheme(forceDark) {
        const b=document.body;
        const dark=forceDark!==undefined?forceDark:!b.hasAttribute('data-theme');
        if(dark){b.setAttribute('data-theme','dark');lsSet(SK.theme,'dark');}
        else{b.removeAttribute('data-theme');lsSet(SK.theme,'light');}
    }

    /* ══════════════════════════════════════
       NAVIGATION
    ══════════════════════════════════════ */
    function navTo(id) {
        document.querySelectorAll('.view-section').forEach(e=>e.classList.remove('active'));
        document.getElementById(id).classList.add('active');
        document.querySelectorAll('.nav-item').forEach(e=>e.classList.remove('active'));
        const map={'view-dashboard':'nav-dash','view-snippets':'nav-snip'};
        if(map[id]) document.getElementById(map[id]).classList.add('active');
    }

    /* ══════════════════════════════════════
       DASHBOARD
    ══════════════════════════════════════ */
    function renderMiniCard(item) {
        const fav=isFav(item.id);
        return `<div class="mini-card${fav?' is-fav':''}" onclick="openAudit('${item.id}')">
            <span class="mini-card-icon">${escapeHtml(item.icon||'📁')}</span>
            <div style="min-width:0;">
                <div class="mini-card-text">${escapeHtml(item.title)}</div>
                <div class="mini-card-sub">${escapeHtml(item.target||'')}${item.subcat?' · '+escapeHtml(item.subcat):''}</div>
            </div>
        </div>`;
    }

    function renderDashboard() {
        const grid=document.getElementById('dashboard-grid');
        const term=document.getElementById('search-input').value.toLowerCase();
        grid.innerHTML='';
        // ── Barre de filtres tags ──
        const allTags=[...new Set(data.flatMap(i=>i.tags||[]))].sort();
        const tfb=document.getElementById('tag-filter-bar');
        if(allTags.length){
            tfb.style.display='flex';
            tfb.style.flexWrap='wrap';
            tfb.style.gap='6px';
            tfb.style.alignItems='center';
            tfb.innerHTML=`<span style="font-size:.72rem;font-weight:700;color:var(--text-muted);text-transform:uppercase;letter-spacing:.8px;">Tags</span>`;
            allTags.forEach(t=>{
                const chip=document.createElement('span');
                chip.className='tag-filter-chip'+(activeTagFilter===t?' active':'');
                chip.textContent='#'+t;
                chip.onclick=()=>{ activeTagFilter=activeTagFilter===t?null:t; renderDashboard(); };
                tfb.appendChild(chip);
            });
            if(activeTagFilter){
                const clr=document.createElement('span');
                clr.className='tag-filter-chip';
                clr.style.cssText='background:var(--bg-app);color:var(--text-muted);border-color:var(--border);';
                clr.textContent='✕ Effacer';
                clr.onclick=()=>{ activeTagFilter=null; renderDashboard(); };
                tfb.appendChild(clr);
            }
        } else { tfb.style.display='none'; }

        // ── Zone Favoris ──
        const favItems = meta.favorites.map(id=>data.find(x=>x.id===id)).filter(Boolean);
        if (favItems.length) {
            const zone=document.createElement('div');
            zone.className='dash-zone';
            zone.innerHTML=`<div class="dash-zone-title">⭐ Favoris <span style="font-size:.7rem;font-weight:400;color:var(--text-muted);">(${favItems.length})</span></div>
                <div class="mini-cards">${favItems.map(renderMiniCard).join('')}</div>`;
            grid.appendChild(zone);
        }

        // ── Zone Récents ──
        const recentItems = meta.recents.map(id=>data.find(x=>x.id===id)).filter(Boolean);
        if (recentItems.length) {
            const zone=document.createElement('div');
            zone.className='dash-zone';
            zone.innerHTML=`<div class="dash-zone-title">🕐 Récents</div>
                <div class="mini-cards">${recentItems.map(renderMiniCard).join('')}</div>`;
            grid.appendChild(zone);
        }

        // ── Zone Plus utilisés ──
        const topIds = getTopUsed();
        const topItems = topIds.map(id=>data.find(x=>x.id===id)).filter(Boolean);
        if (topItems.length >= 2) {
            const zone=document.createElement('div');
            zone.className='dash-zone';
            zone.innerHTML=`<div class="dash-zone-title">📊 Plus utilisés</div>
                <div class="mini-cards">${topItems.map(i=>{
                    const count=meta.usages[i.id]||0;
                    const fav=isFav(i.id);
                    return `<div class="mini-card${fav?' is-fav':''}" onclick="openAudit('${i.id}')">
                        <span class="mini-card-icon">${escapeHtml(i.icon||'📁')}</span>
                        <div style="min-width:0;">
                            <div class="mini-card-text">${escapeHtml(i.title)}</div>
                            <div class="mini-card-sub usage-badge">× ${count}</div>
                        </div>
                    </div>`;
                }).join('')}</div>`;
            grid.appendChild(zone);
        }

        // ── Séparateur si zones présentes ──
        if (favItems.length||recentItems.length||topItems.length>=2) {
            const sep=document.createElement('div');
            sep.style.cssText='height:1px;background:var(--border);margin:16px 0 20px;';
            grid.appendChild(sep);
        }

        // ── Grille principale par catégorie ──
        for (const [catKey,catLabel] of Object.entries(CAT_LABELS)) {
            const catItems=data.filter(i=>i.cat===catKey&&i.title.toLowerCase().includes(term));
            if(!catItems.length) continue;

            const ch=document.createElement('div');
            ch.className='cat-header';
            ch.innerHTML=`<span class="section-title">${catLabel}</span>`;
            grid.appendChild(ch);

            const subcatsPresent=[...new Set(catItems.map(i=>i.subcat).filter(Boolean))];
            if(subcatsPresent.length) {
                const bar=document.createElement('div');
                bar.className='subcat-bar';
                const allActive=!(activeCatFilter===catKey&&activeSubcatFilter);
                bar.innerHTML=`<span class="subcat-chip${allActive?' active':''}" onclick="toggleSubcat('${catKey}',null)">Tous</span>`;
                subcatsPresent.forEach(sc=>{
                    const active=activeCatFilter===catKey&&activeSubcatFilter===sc;
                    bar.innerHTML+=`<span class="subcat-chip${active?' active':''}" onclick="toggleSubcat('${catKey}','${escapeHtml(sc)}')">${escapeHtml(sc)}</span>`;
                });
                grid.appendChild(bar);
            }

            const visible=catItems.filter(i=>{
                const subcatOk=activeCatFilter!==catKey||!activeSubcatFilter||i.subcat===activeSubcatFilter;
                const tagOk=!activeTagFilter||(i.tags||[]).includes(activeTagFilter);
                return subcatOk&&tagOk;
            });

            const g=document.createElement('div');
            g.className='grid-cards';
            visible.forEach(i=>{
                const tag=i.target==='Victime'?'tag-v':i.target==='Témoin'?'tag-t':'tag-m';
                const sub=i.subcat?`<span style="font-size:.7rem;color:var(--text-muted);">${escapeHtml(i.subcat)}</span>`:'';
                const fav=isFav(i.id);
                const usageCount=meta.usages[i.id]||0;
                const tagsHtml=(i.tags||[]).length
                    ?`<div style="display:flex;flex-wrap:wrap;gap:3px;margin-top:2px;">${(i.tags||[]).map(t=>`<span class="tag-chip">#${escapeHtml(t)}</span>`).join('')}</div>`:'';
                const div=document.createElement('div');
                div.className='card'+(fav?' is-fav':'');
                div.draggable=true;
                div.dataset.id=i.id;
                div.innerHTML=`
                    ${fav?'<span class="fav-indicator">⭐</span>':''}
                    <div class="card-tag ${tag}">${escapeHtml(i.target)}</div>
                    <div style="font-size:1.5rem">${escapeHtml(i.icon||'📁')}</div>
                    <div style="font-weight:600">${escapeHtml(i.title)}</div>
                    ${sub}${tagsHtml}
                    ${usageCount>0?`<div class="usage-badge">📂 ${usageCount}×</div>`:''}
                    <div class="card-actions" onclick="event.stopPropagation()">
                        <button class="fav-btn" onclick="toggleFav('${i.id}',event)" title="${fav?'Retirer des favoris':'Ajouter aux favoris'}">${fav?'⭐':'☆'}</button>
                        <button class="mini-btn" onclick="openEditor('${i.id}')" title="Modifier">✎</button>
                        <button class="mini-btn" onclick="duplicateModelFromDash('${i.id}')" title="Dupliquer">📋</button>
                    </div>`;
                div.onclick=()=>openAudit(i.id);
                div.addEventListener('dragstart',ev=>{ dashDragSrc=i.id; ev.dataTransfer.effectAllowed='move'; div.classList.add('dragging'); });
                div.addEventListener('dragend',()=>{ div.classList.remove('dragging'); document.querySelectorAll('.card.drag-target').forEach(el=>el.classList.remove('drag-target')); dashDragSrc=null; });
                div.addEventListener('dragover',ev=>{ ev.preventDefault(); if(dashDragSrc&&dashDragSrc!==i.id) div.classList.add('drag-target'); });
                div.addEventListener('dragleave',()=>div.classList.remove('drag-target'));
                div.addEventListener('drop',ev=>{ ev.preventDefault(); div.classList.remove('drag-target'); if(!dashDragSrc||dashDragSrc===i.id) return; const si=data.findIndex(x=>x.id===dashDragSrc); const ti=data.findIndex(x=>x.id===i.id); if(si<0||ti<0) return; const [moved]=data.splice(si,1); data.splice(ti,0,moved); persistData(); renderDashboard(); });
                g.appendChild(div);
            });
            grid.appendChild(g);
        }
        // Numéros clavier 1-9 sur les cartes
        document.querySelectorAll('#dashboard-grid .card').forEach((card,idx)=>{
            if(idx<9){
                const hint=document.createElement('span');
                hint.className='kbd-hint';
                hint.textContent=String(idx+1);
                card.appendChild(hint);
            }
        });
    }

    function toggleSubcat(catKey,subcat) {
        if(activeCatFilter===catKey&&activeSubcatFilter===subcat){activeCatFilter=null;activeSubcatFilter=null;}
        else{activeCatFilter=catKey;activeSubcatFilter=subcat;}
        renderDashboard();
    }

    /* ══════════════════════════════════════
       AUDITION
    ══════════════════════════════════════ */
    let originalAuditOrder=null;
    function openAudit(id) {
        activeAudit=data.find(x=>x.id===id);
        if(!activeAudit) return;
        activeAudit.qs=normalizeQuestions(activeAudit.qs);
        originalAuditOrder=activeAudit.qs.map(q=>JSON.parse(JSON.stringify(q)));
        trackOpen(id);
        document.getElementById('paper-search').value='';
        const rb=document.getElementById('tb-reset-order'); if(rb) rb.style.display='none';
        navTo('view-audition');
        renderAuditPaper();
        renderQuickSnippets();
    }
    function resetAuditOrder() {
        if(!originalAuditOrder||!activeAudit) return;
        activeAudit.qs=originalAuditOrder.map(q=>JSON.parse(JSON.stringify(q)));
        const rb=document.getElementById('tb-reset-order'); if(rb) rb.style.display='none';
        renderAuditPaper();
        showFeedback('Ordre restauré !');
    }

    function renderAuditPaper() {
        if(!activeAudit) return;
        activeAudit.qs=normalizeQuestions(activeAudit.qs);
        const container=document.getElementById('paper-content');
        container.innerHTML='';
        const header=document.createElement('div');
        header.innerHTML=`<h2 style="margin-bottom:8px;color:var(--text-main);font-size:1.4rem;">${escapeHtml(activeAudit.title)}</h2><div style="margin-bottom:28px;border-bottom:2px solid var(--border);"></div>`;
        container.appendChild(header);
        const totalQs=activeAudit.qs.filter(i=>!isSection(i)).length;
        let qIndex=1;
        // On travaille sur les indices réels dans activeAudit.qs
        activeAudit.qs.forEach((item,idx)=>{
            if(isSection(item)){
                const d=document.createElement('div');
                d.className='paper-section-divider';
                d.innerHTML=`<span class="section-label">${escapeHtml((item.text||'').replace(/---/g,'').trim())}</span>`;
                container.appendChild(d);
                return;
            }
            const finalQ=getReplacedText(item.question);
            const finalDecl=getReplacedText(item.declaration||'');
            const prefix=styles.num?`${qIndex}. `:'';
            const boldClass=styles.bold?'style-bold':'';
            const respClass=styles.resp?'style-response':'';
            const numBadge=styles.num?`<span class="q-num-badge">${qIndex}</span>`:'';
            if(styles.num) qIndex++;
            const declHtml=finalDecl?`
                <div class="q-declaration-box">
                    <div class="q-declaration-header"><span class="q-declaration-icon">📝</span><span class="q-declaration-title">Déclarations de la victime</span><button class="q-declaration-copy" onclick="copyDecl(event,${JSON.stringify(finalDecl).replace(/"/g,'&quot;')})">Copier</button></div>
                    <div class="q-declaration-text">${escapeHtml(finalDecl)}</div>
                </div>`:'';
            const block=document.createElement('div');
            block.className=`paper-q ${boldClass} ${respClass}`.trim();
            block.id=`q-block-${idx}`;
            block.dataset.qText=finalQ.toLowerCase();
            block.draggable=true;
            block.innerHTML=`
                <div class="q-actions">
                    <span class="q-drag-handle" title="Déplacer">⠿</span>
                    <button class="mini-btn" onclick="copySingleQ(${idx})">Copier</button>
                </div>
                <div class="q-header">${numBadge}<div class="q-content">${escapeHtml(prefix+finalQ)}</div></div>
                <div class="q-answer-zone"></div>
                ${declHtml}`;
            // ── drag & drop réordonnancement ──
            let dragSrcIdx=null;
            block.addEventListener('dragstart',ev=>{
                dragSrcIdx=idx;
                ev.dataTransfer.effectAllowed='move';
                ev.dataTransfer.setData('text/plain',String(idx));
                setTimeout(()=>block.classList.add('q-dragging'),0);
            });
            block.addEventListener('dragend',()=>{
                block.classList.remove('q-dragging');
                container.querySelectorAll('.q-drag-over').forEach(el=>el.classList.remove('q-drag-over'));
            });
            block.addEventListener('dragover',ev=>{
                ev.preventDefault();
                const src=parseInt(ev.dataTransfer.getData('text/plain')||'-1');
                if(src===idx) return;
                container.querySelectorAll('.q-drag-over').forEach(el=>el.classList.remove('q-drag-over'));
                block.classList.add('q-drag-over');
            });
            block.addEventListener('dragleave',ev=>{
                if(!block.contains(ev.relatedTarget)) block.classList.remove('q-drag-over');
            });
            block.addEventListener('drop',ev=>{
                ev.preventDefault();
                block.classList.remove('q-drag-over');
                const srcIdx=parseInt(ev.dataTransfer.getData('text/plain'));
                if(isNaN(srcIdx)||srcIdx===idx) return;
                const [moved]=activeAudit.qs.splice(srcIdx,1);
                const newTgt=idx>srcIdx?idx-1:idx;
                activeAudit.qs.splice(newTgt,0,moved);
                const rb2=document.getElementById('tb-reset-order'); if(rb2) rb2.style.display='';
                renderAuditPaper();
            });
            container.appendChild(block);
        });
        updateProgressBar(totalQs);
    }

    function updateProgressBar(totalQs) {
        const total=totalQs||0;
        document.getElementById('progress-counter').textContent=`${total} question${total>1?'s':''}`;
        document.getElementById('progress-label').textContent=escapeHtml(activeAudit?activeAudit.title:'');
        document.getElementById('progress-fill').style.width=(total>0?100:0)+'%';
        document.getElementById('progress-wrap').style.display=total>0?'block':'none';
    }

    function filterPaperQuestions() {
        const term=document.getElementById('paper-search').value.toLowerCase().trim();
        const blocks=document.querySelectorAll('.paper-q');
        let visible=0;
        blocks.forEach(block=>{
            const text=block.getAttribute('data-q-text')||'';
            const match=!term||text.includes(term);
            block.classList.toggle('q-hidden',!match);
            if(match){
                visible++;
                const el=block.querySelector('.q-content');
                if(el){
                    const raw=el.textContent;
                    if(term){
                        const rx=new RegExp('('+term.replace(/[.*+?^${}()|[\]\\]/g,'\\$&')+')','gi');
                        el.innerHTML=escapeHtml(raw).replace(rx,'<mark class="q-highlight">$1</mark>');
                    } else { el.textContent=raw; }
                }
            }
        });
        const total=blocks.length;
        document.getElementById('progress-counter').textContent=term
            ?`${visible} / ${total} question${total>1?'s':''}`
            :`${total} question${total>1?'s':''}`;
    }

    function toggleStyle(key) {
        styles[key]=!styles[key];
        document.getElementById('tog-'+key).classList.toggle('active');
        renderAuditPaper(); filterPaperQuestions();
    }
    function toggleSnipPanel() {
        const panel=document.getElementById('audit-snip-panel');
        const btn=document.getElementById('tb-snip-btn');
        const open=panel.classList.toggle('open');
        if(btn) btn.style.borderColor=open?'var(--primary)':'';
    }
    function toggleSidebar() {
        const sb=document.querySelector('.sidebar');
        const btn=document.getElementById('sidebar-toggle');
        const collapsed=sb.classList.toggle('collapsed');
        btn.textContent=collapsed?'▶':'◀';
        let expandBtn=document.getElementById('sidebar-expand-btn');
        if(!expandBtn){
            expandBtn=document.createElement('button');
            expandBtn.id='sidebar-expand-btn';
            expandBtn.className='sidebar-expand-btn';
            expandBtn.textContent='▶';
            expandBtn.title='Afficher la sidebar';
            expandBtn.onclick=toggleSidebar;
            document.body.appendChild(expandBtn);
        }
        expandBtn.style.display=collapsed?'block':'none';
    }
    function updateVars() { renderAuditPaper(); filterPaperQuestions(); renderQuickSnippets(); }

    /* ══════════════════════════════════════
       COPIE
    ══════════════════════════════════════ */
    async function copyDecl(ev, text) {
        if(ev) ev.stopPropagation();
        await navigator.clipboard.writeText(text);
        showFeedback('Déclaration copiée !');
    }
    async function copySingleQ(idx) {
        const item=activeAudit.qs[idx];
        if(!item||isSection(item)) return;
        const qText=getReplacedText(item.question);
        const html=styles.bold?`<b>${escapeHtml(qText)}</b>`:escapeHtml(qText);
        await copyToClip(html);
    }
    async function copyFullReport() {
        if(!activeAudit) return;
        let html=`<div style="font-family:Arial;font-size:11pt;color:black;">`;
        let qi=1;
        activeAudit.qs.forEach(item=>{
            if(isSection(item)){html+=`<br><p style="color:#2563EB;font-weight:bold;text-decoration:underline;">${escapeHtml((item.text||'').replace(/---/g,'').trim())}</p>`;return;}
            const qText=`${styles.num?`${qi}. `:''}${getReplacedText(item.question)}`;
            const decl=getReplacedText(item.declaration||'');
            if(styles.num) qi++;
            html+=`<p style="margin-bottom:0;">${styles.bold?'<b>'+escapeHtml(qText)+'</b>':escapeHtml(qText)}</p>`;
            if(decl) html+=`<p style="margin:4px 0 8px 0;"><i>Déclarations de la victime :</i> ${escapeHtml(decl)}</p>`;
            html+=styles.resp?`<p style="margin-bottom:15px;">${styles.bold?'<b>Réponse :</b>':'Réponse :'}</p>`:`<p style="margin-bottom:15px;"></p>`;
        });
        html+=`</div>`;
        await copyToClip(html);
    }
    async function copyToClip(html) {
        const bH=new Blob([html],{type:'text/html'});
        const bT=new Blob([html.replace(/<[^>]+>/g,'')],{type:'text/plain'});
        await navigator.clipboard.write([new ClipboardItem({'text/html':bH,'text/plain':bT})]);
        showFeedback('Copié !');
    }
    async function copyRawText(text) {
        await navigator.clipboard.writeText(getReplacedText(text));
        showFeedback('Copié !');
    }
    function exportSingleModel() {
        if(!activeAudit) return;
        const blob=new Blob([JSON.stringify({v:26,data:[activeAudit],snippets:[]})],{type:'application/json'});
        const a=document.createElement('a');
