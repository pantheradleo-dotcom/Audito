    function renderSnippets() {
        const c=document.getElementById('snippets-list');
        c.innerHTML='';
        snippets.forEach((s,i)=>{
            const card=document.createElement('div');
            card.className='snippet-card';
            card.dataset.idx=i;
            card.innerHTML=`
                <div style="flex-grow:1;display:flex;align-items:center;gap:6px;">
                    <span class="snip-text" style="flex-grow:1;">${escapeHtml(s)}</span>
                </div>
                <button class="snip-icon-btn" onclick="copyRawText(${JSON.stringify(s).replace(/"/g,'&quot;')})" title="Copier">ЁЯУЛ</button>
                <button class="snip-icon-btn" onclick="editSnippet(${i})" title="Modifier">тЬО</button>
                <button class="snip-icon-btn" onclick="removeSnippet(${i})" title="Supprimer" style="color:#ef4444;">тЬХ</button>`;
            c.appendChild(card);
        });
