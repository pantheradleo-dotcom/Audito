    function confirmImport() {
        if(!importPending) return;
        const incoming=normalizeDataCollection(importPending.data||[]);
        const checked=[...document.querySelectorAll('.import-item-cb')].map((cb,i)=>cb.checked?i:-1).filter(i=>i>=0);
        if(!checked.length){ alert('Sélectionnez au moins un modèle.'); return; }
        checked.forEach(i=>{
            const item=incoming[i];
            const idx=data.findIndex(x=>x.id===item.id);
            if(idx>=0) data[idx]=item; else data.push(item);
        });
        if(Array.isArray(importPending.snippets)){
            importPending.snippets.forEach(s=>{ if(!snippets.includes(s)) snippets.push(s); });
            persistSnippets();
        }
        persistData(); renderDashboard();
        renderSnippets(); renderQuickSnippets();
        closeImportModal();
        showFeedback(`${checked.length} modèle${checked.length>1?'s':''} importé${checked.length>1?'s':''} !`);
    }
