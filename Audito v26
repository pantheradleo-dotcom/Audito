    /* ══════════════════════════════════════
       HISTORIQUE DES VERSIONS
    ══════════════════════════════════════ */
    function getHistory() {
        return lsGet(SK.history, {});
    }
    function pushHistory(modelId, snapshot) {
        const all = getHistory();
        const entries = all[modelId] || [];
        entries.unshift({ ts: Date.now(), snap: snapshot });
        all[modelId] = entries.slice(0, HISTORY_MAX);
        lsSet(SK.history, all);
    }
    function openHistoryModal() {
        const id = document.getElementById('edit-id').value;
        if (!id) return;
        const all = getHistory();
        const entries = all[id] || [];
        const list = document.getElementById('history-list');
        list.innerHTML = '';
        if (!entries.length) {
            list.innerHTML = '<div class="history-empty">Aucune version sauvegardée pour ce modèle.<br>L\'historique se constitue à chaque enregistrement.</div>';
        } else {
            entries.forEach((entry, i) => {
                const d = new Date(entry.ts);
                const dateStr = d.toLocaleDateString('fr-FR', {day:'2-digit',month:'2-digit',year:'numeric'})
                    + ' à ' + d.toLocaleTimeString('fr-FR', {hour:'2-digit',minute:'2-digit'});
                const qCount = (entry.snap.qs||[]).filter(q=>q.type!=='section'&&(q.question||'').trim()).length;
                const sCount = (entry.snap.qs||[]).filter(q=>q.type==='section').length;
                const summary = `${escapeHtml(entry.snap.title||'Sans titre')} · ${qCount} question${qCount!==1?'s':''}`+(sCount?` · ${sCount} section${sCount!==1?'s':''}`:'');
                const div = document.createElement('div');
                div.className = 'history-entry';
                div.style.cursor = 'pointer';
                div.innerHTML = `
                    <div style="font-size:1.4rem;flex-shrink:0;">${escapeHtml(entry.snap.icon||'📁')}</div>
                    <div class="history-meta">
                        <div class="history-date">${i===0?'⭐ Dernière version · ':''}${dateStr}</div>
                        <div class="history-summary">${summary}</div>
                    </div>
                    <button class="action-btn" style="width:auto;padding:6px 12px;font-size:.78rem;" onclick="restoreHistory('${modelId}',${i});event.stopPropagation();">Restaurer</button>`;
                list.appendChild(div);
            });
        }
        document.getElementById('modal-history').style.display = 'flex';
    }
    function closeHistoryModal() {
        document.getElementById('modal-history').style.display = 'none';
    }
    function restoreHistory(modelId, idx) {
        if (!confirm('Restaurer cette version ? Les modifications non sauvegardées seront perdues.')) return;
        const all = getHistory();
        const entry = (all[modelId]||[])[idx];
        if (!entry) return;
        closeHistoryModal();
        // Recharger l'éditeur avec le snapshot
        const snap = entry.snap;
        document.getElementById('edit-title').value = snap.title || '';
        document.getElementById('edit-cat').value = snap.cat || 'personnes';
        buildSubcatOptions(snap.cat||'personnes', snap.subcat||'');
        document.getElementById('edit-target').value = snap.target || 'Victime';
        currentEditorIcon = snap.icon || '📁';
        buildIconPicker(currentEditorIcon);
        currentQs = normalizeQuestions(snap.qs||[]);
        renderEd();
        onEditorChange();
        showFeedback('Version restaurée — pensez à enregistrer !');
    }

    /* Sauvegarde */
    function saveModel() {
        const v = getEditorValidation();
        if (!v.hasTitle) { document.getElementById('edit-title').focus(); renderEditorStatusBar(); return; }
        const id=document.getElementById('edit-id').value;
        currentQs=normalizeQuestions(currentQs).filter(item=>{
            if(isSection(item)) return (item.text||'').trim().length>0;
            return (item.question||'').trim().length>0;
        });
        const noteEl=document.getElementById('edit-note');
        const model={
            id:id||'c'+Date.now(), icon:currentEditorIcon,
            cat:document.getElementById('edit-cat').value,
            subcat:document.getElementById('edit-subcat').value,
            title:v.title, target:document.getElementById('edit-target').value,
            tags:[...currentEditorTags],
            note:noteEl?noteEl.value.trim():'',
            qs:currentQs
        };
        if(id){
            const idx=data.findIndex(x=>x.id===id);
            if(idx!==-1) pushHistory(id, JSON.parse(JSON.stringify(data[idx]))); // snapshot avant écrasement
            data[idx>=0?idx:data.length]=model;
        } else data.push(model);
        persistData();renderDashboard();
        if(activeAudit&&activeAudit.id===model.id){activeAudit=model;renderAuditPaper();}
        closeEditor();
    }

    function deleteModel() {
        if(confirm('Supprimer ce modèle ?')){
            const id=document.getElementById('edit-id').value;
            data=data.filter(x=>x.id!==id);
            // Nettoyer les métadonnées
            meta.favorites=meta.favorites.filter(x=>x!==id);
            meta.recents=meta.recents.filter(x=>x!==id);
            delete meta.usages[id];
            const hist=getHistory(); delete hist[id]; lsSet(SK.history,hist);
            persistData();persistMeta();renderDashboard();
            if(activeAudit&&activeAudit.id===id){activeAudit=null;navTo('view-dashboard');}
            closeEditor();
        }
    }

    function duplicateModel() {
        const id=document.getElementById('edit-id').value;
        const title=document.getElementById('edit-title').value.trim();
        const sourceCopy={
            id:'c'+Date.now(), icon:currentEditorIcon,
            cat:document.getElementById('edit-cat').value,
            subcat:document.getElementById('edit-subcat').value,
            title:(title||'Nouveau modèle')+' (copie)',
            target:document.getElementById('edit-target').value,
            qs:JSON.parse(JSON.stringify(currentQs))
        };
        if(id){
            const source=data.find(x=>x.id===id);
            if(source) Object.assign(sourceCopy,{...JSON.parse(JSON.stringify(source)),id:sourceCopy.id,title:source.title+' (copie)'});
        }
        data.push(sourceCopy);persistData();renderDashboard();
        closeEditor();
        setTimeout(()=>openEditor(sourceCopy.id),50);
    }

    function duplicateModelFromDash(id) {
        const source=data.find(x=>x.id===id);
        if(!source) return;
        const copy={...JSON.parse(JSON.stringify(source)),id:'c'+Date.now(),title:source.title+' (copie)'};
        data.push(copy);persistData();renderDashboard();
        showFeedback('Modèle dupliqué !');
    }

    /* ══════════════════════════════════════
       MODÈLES COMPOSITES
    ══════════════════════════════════════ */
    function openCompositeModal() {
        compositeSelected=[];
        document.getElementById('composite-title').value='';
        renderCompositeSourceList();renderCompositeOrderList();
        document.getElementById('modal-composite').style.display='flex';
    }
    function closeCompositeModal() { document.getElementById('modal-composite').style.display='none'; }
    function renderCompositeSourceList() {
        const c=document.getElementById('composite-source-list');
        c.innerHTML='';
        data.forEach(item=>{
            const sel=compositeSelected.includes(item.id);
            c.innerHTML+=`
                <div class="composite-source-item ${sel?'selected':''}" onclick="toggleCompositeSource('${item.id}')">
                    <span>${escapeHtml(item.icon||'📁')} ${escapeHtml(item.title)}</span>
                    <span style="font-size:.75rem;color:var(--text-muted);">${sel?'✓':''}</span>
                </div>`;
        });
    }
    function toggleCompositeSource(id) {
        const i=compositeSelected.indexOf(id);
        if(i===-1) compositeSelected.push(id);
        else compositeSelected.splice(i,1);
        renderCompositeSourceList();renderCompositeOrderList();
    }
    function renderCompositeOrderList() {
        const c=document.getElementById('composite-order-list');
        c.innerHTML='';
        if(!compositeSelected.length){c.innerHTML='<div style="color:var(--text-muted);font-size:.85rem;">Sélectionnez des modèles ci-dessus</div>';return;}
        compositeSelected.forEach((id,i)=>{
            const item=data.find(x=>x.id===id);if(!item) return;
            c.innerHTML+=`
                <div class="composite-order-item">
                    <span>${escapeHtml(item.icon||'📁')} ${escapeHtml(item.title)}</span>
                    <div style="margin-left:auto;display:flex;gap:4px;">
                        <button class="mini-btn" onclick="moveComposite(${i},-1)">↑</button>
                        <button class="mini-btn" onclick="moveComposite(${i},1)">↓</button>
                    </div>
                </div>`;
        });
    }
    function moveComposite(i,dir) {
        const ni=i+dir;if(ni<0||ni>=compositeSelected.length) return;
        [compositeSelected[i],compositeSelected[ni]]=[compositeSelected[ni],compositeSelected[i]];
        renderCompositeOrderList();
    }
    function saveComposite() {
        if(compositeSelected.length<2){alert('Sélectionnez au moins 2 modèles.');return;}
        const title=document.getElementById('composite-title').value.trim();
        if(!title){document.getElementById('composite-title').focus();return;}
        let qs=[];
        compositeSelected.forEach((id,i)=>{
            const src=data.find(x=>x.id===id);if(!src) return;
            if(i>0) qs.push({type:'section',text:`--- ${src.title.toUpperCase()} ---`,declaration:''});
            qs=qs.concat(JSON.parse(JSON.stringify(src.qs)));
        });
        const first=data.find(x=>x.id===compositeSelected[0]);
        const composite={
            id:'c'+Date.now(), icon:'🔗',
            cat:first?first.cat:'personnes', subcat:'',
            title, target:first?first.target:'Victime', qs
        };
        data.push(composite);persistData();renderDashboard();
        closeCompositeModal();showFeedback('Modèle composite créé !');
    }

    /* ══ DÉMARRAGE ══ */
    (function(){
        const t=localStorage.getItem('audito25_theme')||localStorage.getItem('audito21_theme');
        if(t==='dark') document.body.setAttribute('data-theme','dark');
    })();
    init();
</script>
